{
  "manifest_version": 3,
  "name": "AI Text Detector",
  "version": "1.0.0",
  "description": "Detect AI-generated text on any webpage using ELECTRA deep learning model. Scan full pages, selected text, or paste your own text to analyze.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://dipaghosh56-electra-ai-vs-human.hf.space/*",
    "https://translate.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Text Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/html2pdf.bundle.min.js", "report-generator.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.worker.min.js", "lib/html2pdf.bundle.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
